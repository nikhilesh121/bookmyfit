# Backend
NODE_ENV=development
PORT=3003

# Option A: connection string (takes priority — required for Neon/cloud Postgres)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option B: individual vars (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=bookmyfit
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cashfree Payments
CASHFREE_ENV=sandbox
CASHFREE_CLIENT_ID=TEST_CLIENT_ID
CASHFREE_CLIENT_SECRET=TEST_CLIENT_SECRET
API_BASE_URL=http://localhost:3003

# Resend (email notifications) — get key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=BookMyFit <noreply@bookmyfit.in>
GYM_PANEL_URL=https://gym.bookmyfit.in
CORP_PANEL_URL=https://corporate.bookmyfit.in

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_S3_BUCKET=bookmyfit-uploads

# OTP / SMS
# Production launch uses MSG91 OTP Widget in SMS-only mode.
MSG91_AUTH_KEY=xxxxx
MSG91_OTP_WIDGET_ID=3666616b6e44333836303230
# Optional reviewer/test bypasses: phone:otp,phone:otp. Keep this limited.
OTP_TEST_NUMBERS=9040283338:123456
# Keep false in production so the app does not display OTP hints.
OTP_EXPOSE_DEV_OTP=false

# Legacy Twilio placeholders. Not used when MSG91_AUTH_KEY and MSG91_OTP_WIDGET_ID are set.
TWILIO_ACCOUNT_SID=xxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3003
EXPO_PUBLIC_API_URL=http://localhost:3003
