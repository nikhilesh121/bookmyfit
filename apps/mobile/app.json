{
  "expo": {
    "name": "BookMyFit",
    "slug": "bookmyfit",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bookmyfit",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0f0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.bookmyfit.app"
    },
    "android": {
      "package": "in.bookmyfit.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "BookMyFit needs camera access to scan member QR codes at check-in."
        }
      ]
    ],
    "extra": {
      "cashfreeBaseUrl": "https://sandbox.cashfree.com",
      "apiUrl": "https://bookmyfit.in",
      "router": {},
      "eas": {
        "projectId": "deab094a-848d-483d-9e83-d7f69adac2da"
      }
    },
    "owner": "qwegle"
  }
}
