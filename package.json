{
  "name": "bookmyfit",
  "version": "1.0.0",
  "private": true,
  "description": "BookMyFit - Fitness Subscription Marketplace Platform",
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:tasklist": "pnpm --filter tasklist dev",
    "dev:admin": "pnpm --filter admin-panel dev",
    "dev:gym": "pnpm --filter gym-panel dev",
    "dev:corporate": "pnpm --filter corporate-panel dev",
    "dev:mobile": "pnpm --filter mobile start",
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:landing": "pnpm --filter landing dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf node_modules .next dist build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.1.0",
    "prettier": "^3.2.4",
    "turbo": "^1.12.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=8.0.0"
  }
}
